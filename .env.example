# Template for .env — copy to .env and fill in, then never commit .env.
#   cp .env.example .env
# experiments/env.sh loads this (set -a; source .env) so the values reach
# huggingface-cli / transformers as environment variables.

# HuggingFace token: https://huggingface.co/settings/tokens
# Needed for gated models and to avoid anonymous rate limits. Qwen3-32B is
# public, so a token is optional for the current sweep but kept for headroom.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
